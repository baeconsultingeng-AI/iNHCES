        DB4[("projects / predictions\nreports")]
        DB5[("ml_models / users\naudit_log")]
    end

    %% ── STORAGE ───────────────────────────────────────────────────────────
    subgraph STORAGE["STORAGE LAYER - Cloudflare R2"]
        direction LR
        S1["PDF Reports - per project"]
        S2["Model Artifacts - .pkl / .json"]
        S3["Training Datasets - versioned CSVs"]
    end

    %% ── AIRFLOW PIPELINE ─────────────────────────────────────────────────
    subgraph PIPELINE["PIPELINE LAYER - Apache Airflow on Railway"]
