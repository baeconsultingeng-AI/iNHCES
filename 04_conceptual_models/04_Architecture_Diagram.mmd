graph TD

    %% ── USERS ─────────────────────────────────────────────────────────────
    subgraph USERS["USER LAYER"]
        direction LR
        U1[QS Professional]
        U2[Researcher / PI]
        U3[System Admin]
    end

    %% ── FRONTEND ──────────────────────────────────────────────────────────
    subgraph FRONTEND["PRESENTATION LAYER - Vercel CDN"]
        direction LR
        FE1["index.html - Cost Estimator Form"]
        FE2["dashboard.html - Pipeline Monitor"]
        FE3["app.js / styles.css - Shared Logic"]
        FE1 --- FE3
        FE2 --- FE3
    end

    %% ── BACKEND API ───────────────────────────────────────────────────────
    subgraph BACKEND["API LAYER - FastAPI on Railway"]
        direction TB
        AUTH["JWT Auth Middleware"]
        API1["POST /estimate - ML cost prediction"]
        API2["GET /macro - Macro data feed"]
        API3["CRUD /projects - Project management"]
        API4["POST /reports - PDF report generation"]
        API5["GET /pipeline - Airflow status"]
        AUTH --> API1 & API2 & API3 & API4 & API5
    end

    %% ── ML LAYER ──────────────────────────────────────────────────────────
    subgraph MLAYER["ML LAYER - MLflow on Railway"]
