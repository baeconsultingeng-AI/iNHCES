    P8 -->|"PSI drift check / emergency retrain"| MLAYER
    E1 -->|"HTTP API"| P4 & P6
    E2 -->|"HTTP API"| P1
    E3 -->|"HTTP API"| P1
    E4 & E5 -->|"web scraper"| P2 & P3
    E6 -->|"HTTP / scraper"| P4
    E7 -->|"CSV upload"| P5
    CICD -->|"deploy on merge to main"| BACKEND
    CICD -->|"deploy on merge to main"| FRONTEND
