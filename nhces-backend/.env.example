# iNHCES Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. This file (.env.example) is safe to commit.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
CLOUDFLARE_R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET=inhces-storage

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=nhces_cost_estimation

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_API_URL=http://localhost:8080/api/v1
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-32-byte-hex-secret-key
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://nhces.vercel.app

# ── Data Source API Keys (optional — synthetic fallback used if absent) ───────
EIA_API_KEY=your-eia-api-key
FRED_API_KEY=your-fred-api-key

